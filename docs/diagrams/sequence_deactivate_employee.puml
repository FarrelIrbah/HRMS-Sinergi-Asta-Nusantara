@startuml sequence_deactivate_employee
title Sequence Diagram — UC-HRMS-15 Menonaktifkan Karyawan

skinparam backgroundColor white
skinparam shadowing false
skinparam defaultFontName "Arial"
skinparam defaultFontSize 12
skinparam roundcorner 8
skinparam titleFontSize 14
skinparam titleFontStyle bold

actor "HR Admin" as HR
participant "Halaman\n/employees/[id]" as UI <<boundary>>
participant "DeactivateDialog" as Dlg <<boundary>>
participant "deactivateEmployee\nAction" as Act <<control>>
participant "requireHRAdmin" as Guard <<control>>
participant "deactivateEmployee\nSchema (zod)" as Val <<control>>
participant "deactivateEmployee\n(service)" as Svc <<control>>
participant "Prisma\n$transaction" as TX <<control>>
participant "createAuditLog" as Audit <<control>>
database "Employee" as E1 <<entity>>
database "User" as E2 <<entity>>
database "AuditLog" as E3 <<entity>>

HR -> UI : klik "Nonaktifkan Karyawan"
UI -> Dlg : buka dialog konfirmasi
HR -> Dlg : isi terminationDate & terminationReason
HR -> Dlg : klik "Konfirmasi"
Dlg -> Act : deactivateEmployeeAction(employeeId, formData)
Act -> Guard : auth() + cek role
Guard --> Act : authResult

alt Tidak otorisasi
  Act --> Dlg : { success: false, error: "Akses ditolak" }
  Dlg --> HR : toast error
else Otorisasi sukses
  Act -> Val : deactivateEmployeeSchema.safeParse

  alt Validasi gagal
    Val --> Act : ZodError
    Act --> Dlg : { success: false, error }
    Dlg --> HR : pesan validasi
  else Validasi berhasil
    Val --> Act : { terminationDate, terminationReason }
    Act -> Svc : deactivateEmployee(employeeId, data, actorId)
    Svc -> E1 : findUnique({ id, select: { userId, isActive, namaLengkap } })

    alt Employee tidak ditemukan
      Svc --> Act : "Karyawan tidak ditemukan"
      Act --> Dlg : error
    else Sudah nonaktif
      Svc --> Act : "Karyawan sudah tidak aktif"
      Act --> Dlg : error
    else Aktif
      E1 --> Svc : oldEmployee
      Svc -> TX : prisma.$transaction(tx => ...)
      TX -> E1 : employee.update({\n  isActive: false,\n  terminationDate,\n  terminationReason })
      TX -> E2 : user.update({\n  id: userId,\n  isActive: false })
      TX --> Svc : employee
      Svc -> Audit : createAuditLog(UPDATE, EMPLOYEE,\n  oldValue, newValue)
      Audit -> E3 : auditLog.create
      Svc --> Act : { success: true, data }
      Act --> Dlg : revalidatePath("/employees"),\nsukses
      Dlg --> HR : toast sukses + halaman refresh
    end
  end
end
@enduml
