@startuml sequence_view_audit_log
title Sequence Diagram — UC-HRMS-09 Melihat Log Audit

skinparam backgroundColor white
skinparam shadowing false
skinparam defaultFontName "Arial"
skinparam defaultFontSize 12
skinparam roundcorner 8
skinparam titleFontSize 14
skinparam titleFontStyle bold

actor "Superadmin" as SA
participant "Halaman\n/audit-log" as UI <<boundary>>
participant "AuditLogFilters" as Flt <<boundary>>
participant "auth()" as Sess <<control>>
participant "getAuditLogs" as Get <<control>>
participant "getAuditLogUsers" as GetU <<control>>
participant "getAuditLogModules" as GetM <<control>>
participant "getAuditLogById" as GetById <<control>>
database "AuditLog" as E1 <<entity>>
database "User" as E2 <<entity>>

SA -> UI : akses /audit-log
UI -> Sess : auth()
Sess --> UI : session

alt session tidak valid
  UI --> SA : redirect /login
else session valid
  alt role bukan SUPER_ADMIN
    UI --> SA : redirect /dashboard
  else role SUPER_ADMIN
    UI -> Get : getAuditLogs(filters)
    Get -> E1 : findMany where (userId, module,\n  createdAt range) include user
    E1 --> Get : logs
    Get -> E1 : count(where)
    E1 --> Get : total
    Get --> UI : { data, total, page, pageSize }
    UI -> GetU : getAuditLogUsers()
    GetU -> E1 : findMany distinct userId\n  select user
    GetU --> UI : daftar pengguna
    UI -> GetM : getAuditLogModules()
    GetM -> E1 : findMany distinct module
    GetM --> UI : daftar modul
    UI --> SA : tampilkan tabel + filter\n+ ringkasan create/update/delete

    SA -> Flt : ubah filter (pengguna, modul, periode)
    Flt -> UI : update searchParams URL
    UI -> Get : getAuditLogs(filtersBaru)
    Get --> UI : data hasil filter
    UI --> SA : refresh tabel

    alt Lihat detail satu baris
      SA -> UI : klik baris log
      UI -> GetById : getAuditLogById(id)
      GetById -> E1 : findUnique include user
      E1 --> GetById : log + user
      GetById --> UI : detail (oldValue, newValue)
      UI --> SA : tampilkan /audit-log/[id]
    end
  end
end
@enduml
